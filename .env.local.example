# Copy this file to .env.local and fill the values.
# These are also set in Vercel under claused/tedxnewy → Project Settings → Environment Variables.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Resend — for transactional emails (e.g. admin notifications when a school
# submits a Youth Futures Lab EOI). Get an API key at https://resend.com.
# Leave RESEND_API_KEY unset to no-op email sends in local dev.
RESEND_API_KEY=re_...
# Optional: override the From address. Defaults to Resend's sandbox sender.
# Once tedxnewy.com.au is verified in Resend, change to something like:
# RESEND_FROM=TEDxNewy <noreply@tedxnewy.com.au>
RESEND_FROM=
